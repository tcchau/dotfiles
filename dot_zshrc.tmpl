function gitchangelog() {
  if [[ -n $1 ]] ; then
    git log --grep="Merge branch" $1..HEAD
  else
    echo "Requires commit hash as argument"
  fi
}

function fif() {
  if [[ -n $1 && -n $2 ]] ; then
    find . -name $1 -exec grep -Hin $2 {} \;
  else
    echo "Requires 2 patterns as arguments"
  fi
}

function rmd() {
  pandoc $1 | lynx -stdin
}

function reapdockerimages() {
  docker rm $(docker ps -qa --no-trunc --filter "status=exited")
  docker rmi $(docker images | grep "none" | awk '/ / { print $3 }')
  docker rmi $(docker images --filter "dangling=true" -q --no-trunc)
}

function list-unmerged {
  git ls-files --unmerged | cut -f2 | sort -u ;
}

# List opencode processes with port + cwd
list-opencodes() {
  local pids port cwd start
  pids=($(pgrep -f "opencode.*--port" 2>/dev/null))
  (( ${#pids[@]} )) || { echo "No opencode --port processes"; return; }
  for pid in "${pids[@]}"; do
    port=$(lsof -w -iTCP -sTCP:LISTEN -P -n -a -p "$pid" 2>/dev/null | awk 'NR>1{split($9,a,":");print a[length(a)]; exit}')
    cwd=$(lsof -p "$pid" 2>/dev/null | awk '$4=="cwd"{print $9; exit}')
    start=$(ps -o lstart= -p "$pid")
    printf "%-6s port=%-6s cwd=%-50s start=%s\n" "$pid" "${port:-?}" "${cwd:-?}" "$start"
  done
}

# 2) Check if a WezTerm pane still references it (fast heuristic: pane CWD match)
list-wezterm-panes() {
  wezterm cli list --format json 2>/dev/null | jq -r '.[] | "\(.pane_id)\t\(.cwd)\t\(.title)"'
}


