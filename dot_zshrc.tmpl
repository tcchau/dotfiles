# function for using different configurations of neovim
vv() {
  # Find all nvim-* configs in ~/.config
  local configs=($(fd --max-depth 1 --glob 'nvim-*' ~/.config))

  # If no nvim-* configs exist, load Neovim with the default config
  if [[ ${#configs[@]} -eq 0 ]]; then
    echo "No custom configs found. Loading default Neovim configuration..."
    nvim "$@"
    return
  fi

  # Use fzf to select a config
  local config=$(printf "%s\n" "${configs[@]}" | fzf --prompt="Neovim Configs > " --height=~50% --layout=reverse --border --exit-0)

  # If I exit fzf without selecting a config, don't open Neovim
  [[ -z $config ]] && echo "No config selected" && return

  # Open Neovim with the selected config
  NVIM_APPNAME=$(basename "$config") nvim "$@"
}

# add node binary path to PATH if in a node project directory
function update_node_path() {
  # Remove existing node_modules/.bin entries
  PATH=$(echo $PATH | tr ':' '\n' | grep -v "node_modules/\.bin" | tr '\n' ':' | sed 's/:$//')

  # Collect all node_modules/.bin paths from current dir up to root
  local current_dir=$PWD
  while [[ "$current_dir" != "/" ]]; do
    local bin_path="$current_dir/node_modules/.bin"
    if [[ -d "$bin_path" ]]; then
      PATH="$bin_path:$PATH"  # Closest directories get priority
    fi
    current_dir=$(dirname "$current_dir")
  done

  export PATH
}



